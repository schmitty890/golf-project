# MongoDB Connection String
# Use different database names for dev vs production:
#   Development: golf-project-dev
#   Production:  golf-project
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/golf-project-dev

# JWT Secret Key (use a strong random string in production)
JWT_SECRET=your-secret-key-here

# Server Port (optional, defaults to 5001)
PORT=5001

# --- Email notifications (optional; emails silently no-op until these are set) ---
# Gmail: enable 2-Step Verification, then create an App Password and use it as SMTP_PASS
# (NOT your real Gmail password). Or use a provider like Resend / SendGrid / Mailgun.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_FROM=VOLW Firewood <youraddress@gmail.com>
OWNER_EMAIL=youraddress@gmail.com

# Branding shown in emails
BUSINESS_NAME=VOLW Firewood
SERVICE_AREA=The Vineyards on Lake Wylie

# Payment instructions shown in emails
VENMO_HANDLE=your-venmo-username

# Optional: adds a "leave a review" link in the thank-you email
SITE_URL=https://your-site-url
