# Frontend environment variables (Create React App — must be prefixed REACT_APP_ and are
# baked in at build time). Copy to .env.development for local dev or set in the host (Netlify).

# Base URL of the backend API.
REACT_APP_API_URL=http://localhost:5001

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX). Leave unset to disable analytics
# (it stays off in local dev). Set it in production to start tracking.
REACT_APP_GA_ID=
